{
  "name": "dev-voice",
  "publisher": "your-publisher-name",
  "displayName": "Dev Voice (Universal)",
  "description": "Premium sound effects for coding events. Built for VS Code, Cursor, Antigravity, and AI-powered IDEs.",
  "version": "0.0.1",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/dev-voice"
  },
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dev-voice.enable",
        "title": "Dev Voice: Enable Sounds"
      },
      {
        "command": "dev-voice.disable",
        "title": "Dev Voice: Disable Sounds"
      },
      {
        "command": "dev-voice.search",
        "title": "Dev Voice: Search Workspace (Audible)"
      },
      {
        "command": "dev-voice.dashboard",
        "title": "Dev Voice: Open Dashboard"
      }
    ],
    "configuration": {
      "title": "Dev Voice",
      "properties": {
        "dev-voice.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable all sounds."
        },
        "dev-voice.volume": {
          "type": "number",
          "default": 1.0,
          "description": "Volume level (0.0 to 1.0)."
        },
        "dev-voice.sounds.startup": { "type": "boolean", "default": true },
        "dev-voice.sounds.searchFail": { "type": "boolean", "default": true },
        "dev-voice.sounds.delete": { "type": "boolean", "default": true },
        "dev-voice.sounds.branchDirty": { "type": "boolean", "default": true },
        "dev-voice.sounds.errorSingle": { "type": "boolean", "default": true },
        "dev-voice.sounds.errorMedium": { "type": "boolean", "default": true },
        "dev-voice.sounds.errorHigh": { "type": "boolean", "default": true },
        "dev-voice.sounds.fixedMultiple": { "type": "boolean", "default": true },
        "dev-voice.sounds.mergeConflict": { "type": "boolean", "default": true },
        "dev-voice.sounds.mergeConflictHigh": { "type": "boolean", "default": true },
        "dev-voice.sounds.closeError": { "type": "boolean", "default": true },
        "dev-voice.sounds.closeDirty": { "type": "boolean", "default": true }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "eslint": "^8.50.0",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "play-sound": "^1.1.6"
  }
}
